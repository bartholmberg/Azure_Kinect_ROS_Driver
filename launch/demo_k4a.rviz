      Name: Landmark Poses
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /constraint_list
      Name: Constraints
      Namespaces:
        {}
      Queue Size: 3
      Value: false
    - Acceleration properties:
        Acc. vector alpha: 0.800000011920929
        Acc. vector color: 255; 255; 127
        Acc. vector scale: 0.019999999552965164
        Derotate acceleration: true
        Enable acceleration: true
      Axes properties:
        Axes scale: 0.019999999552965164
        Enable axes: false
      Box properties:
        Box alpha: 0.6000000238418579
        Box color: 155; 185; 255
        Enable box: false
        x_scale: 0.10000000149011612
        y_scale: 0.10000000149011612
        z_scale: 0.10000000149011612
      Class: rviz_imu_plugin/Imu
      Enabled: true
      Name: Imu
      Queue Size: 5
      Topic: /imu
      Unreliable: false
      Value: true
      fixed_frame_orientation: false
    - Alpha: 0.699999988079071
      Class: rviz/Map
      Color Scheme: map
      Draw Behind: true
      Enabled: true
      Name: Map
      Topic: /map
      Unreliable: false
      Use Timestamp: false
      Value: true
    - Alpha: 1
      Auto Size:
        Auto Size Factor: 1
        Value: true
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 9.734750747680664
        Min Value: 0.28387945890426636
        Value: true
      Axis: X
      Channel Name: intensity
      Class: rviz/DepthCloud
      Color: 255; 255; 255
      Color Image Topic: /rgb_to_depth/image_raw
      Color Transformer: RGB8
      Color Transport Hint: raw
      Decay Time: 0
      Depth Map Topic: /depth/image_raw
      Depth Map Transport Hint: raw
      Enabled: true
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: DepthCloud
      Occlusion Compensation:
        Occlusion Time-Out: 30
        Value: false
      Position Transformer: XYZ
      Queue Size: 5
      Selectable: true
      Size (Pixels): 1
      Style: Points
      Topic Filter: true
      Use Fixed Frame: true
      Use rainbow: true
      Value: true
    - Class: rviz/Camera
      Enabled: true
      Image Rendering: background and overlay
      Image Topic: /rgb/image_raw
      Name: Camera
      Overlay Alpha: 0.5
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: true
      Visibility:
        Constraints: true
        DepthCloud: true
        Grid: true
        Imu: true
        Landmark Poses: true
        Map: true
        PointCloud2: true
        RobotModel: true
        Submaps: true
        TF: true
        Trajectories: true
        Value: true
      Zoom Factor: 1
  Enabled: true
  Global Options:
    Background Color: 100; 100; 100
    Default Light: true
    Fixed Frame: base_link
    Frame Rate: 15
  Name: root
  Tools:
    - Class: rviz/Interact
