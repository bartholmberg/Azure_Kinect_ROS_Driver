Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Status1
        - /TF1
        - /TF1/Frames1
        - /Submaps1/Submaps1/Trajectory 01
        - /PointCloud21
        - /Trajectories1
