<robot name="azure-kinect" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="tf_prefix" default=""/>
  <material name="black">
    <color rgba="0. 0. 0. 1" />
  </material>
  <material name="dark_grey">
    <color rgba="0.1 0.1 0.1 1" />
  </material>
  <material name="grey">
    <color rgba="0.6 0.6 0.6 1" />
 </material>
  <material name="gray">
    <color rgba="0.2 0.2 0.2 1" />
  </material>
  <material name="brightRed">
    <color rgba="1.0 0 0 1.0" />
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1" />
  </material>
    <material name="orange">
    <color rgba="1.0 0.5 0.2 1" />
  </material>
  
  <link name="base_link">
  	  <parent link="odom" />
    <visual>
      <origin xyz="-0.013 0. 0." />
      <geometry>
        <box size="0.026 0.103 0.039" />
      </geometry>
      <material name="brightRed" />
    </visual>
  </link>
    <link name="imu">
      <parent link="odom" />
    <visual>
      <origin xyz="0 0 0" />
      <geometry>
        <box size="0.06 0.04 0.02" />
      </geometry>
      <material name="orange" />
    </visual>
  </link>
  <link name="depth_camera_link">
    <parent link="map" />
    <visual>
      <origin xyz="0 0 0" />
      <geometry>
        <cylinder length="0.05" radius="0.03" />
      </geometry>
      <material name="gray" />
    </visual>
  </link>


  <link name="camera_body">
    <visual>
      <origin xyz="0. 0. 0." />
      <geometry>
        <box size="0.0994 0.0996 0.023" />
      </geometry>
      <material name="white" />
    </visual>
  </link>
  <link name="camera_visor">
    <visual>
      <origin xyz="-0.0128 0. 0." />
      <geometry>
        <box size="0.026 0.101 0.037" />
      </geometry>
      <material name="black" />
    </visual>
  </link>
  <joint name="base_to_body" type="fixed">
    <parent link="base_link" />
    <child link="camera_body" />
    <origin xyz="-0.0757 0. 0.008" rpy="0. 0. 0." />
  </joint>

  <joint name="base_to_visor" type="fixed">
    <parent link="base_link" />
    <child link="camera_visor" />
    <origin xyz="0. 0. 0." rpy="0. 0. 0." />
  </joint>

  <joint name="base_imu_joint" type="fixed">
    <parent link="depth_camera_link" />
    <child link="imu" />
    <origin rpy="0 0 0" xyz="0 0 0" />
  </joint>
  <joint name="base_depth_joint" type="fixed">
    <parent link="base_link" />
    <child link="depth_camera_link" />
	<!--origin rpy="0 -1.570796 3.141593" xyz="0.000 0 0.0000" -->
    <origin rpy="0 0 0" xyz="0.000 0 0.0000" />
  </joint>
</robot>